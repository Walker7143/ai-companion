minimax:
  api_key: "${MINIMAX_API_KEY}"
  base_url: "https://api.minimax.chat/v1"
  model: "MiniMax-M2.7"
  max_context_tokens: 20000   # 模型上下文上限（token），超限触发压缩

openai:
  api_key: "${OPENAI_API_KEY}"
  base_url: "https://api.openai.com/v1"
  model: "gpt-4o"
  max_context_tokens: 20000 # 模型上下文上限（token），超限触发压缩

claude:
  api_key: "${ANTHROPIC_API_KEY}"
  base_url: "https://api.anthropic.com/v1"
  model: "claude-sonnet-4-20250514"
  max_context_tokens: 20000 # 模型上下文上限（token），超限触发压缩

mimo:
  api_key: "${MIMO_API_KEY}"
  base_url: "https://token-plan-cn.xiaomimimo.com/v1"
  model: "mimo-v2.5-pro"
  max_context_tokens: 1048576 # 1M 上下文上限（token），超限触发压缩

ollama:
  base_url: "http://localhost:11434"
  model: "qwen2.5:7b"
  max_context_tokens: 20000 # 模型上下文上限（token），超限触发压缩

memory:
  embedding: "local"         # "local" | "none"
  embedding_model: "all-MiniLM-L6-v2"  # sentence-transformers 模型名
  max_working_turns: 20       # 工作记忆保留轮数
  hard_limit_chars: 5000      # 硬上限，超限同步压缩
  soft_limit_chars: 3000      # 软上限，异步压缩
  prompt_char_limit: 12000    # 注入 system prompt 的记忆文本上限；手动用户理解很多时可调大

fallback:
  enabled: false

# ============================================
# 技能系统配置
# ============================================
# 每个技能通过 model 字段指定默认模型类型，
# 然后在对应模型配置块中填写参数。
# 支持内置模型，也支持自定义 HTTP API。
# ============================================

skills:
  image_generation:
    enabled: true
    auto: true
    base_url: "https://api.openai.com/v1"
    model: "gpt-image-1"
    api_key: "${OPENAI_API_KEY}"
    output_dir: "data/bots/_images"

  image_understanding:
    enabled: true
    auto: true
    base_url: "https://api.openai.com/v1"
    model: "gpt-4o"
    api_key: "${OPENAI_API_KEY}"
    max_image_size_mb: 8
    max_images_per_message: 3

  video_generation:
    model: "minimax"          # 默认模型：minimax | 自定义

    # --- MiniMax 视频生成 ---
    minimax:
      model: "MiniMax-Hailuo-2.3"  # T2V / I2V 模型
      # I2V: 添加 first_frame 参数
      # SEF (首尾帧): 使用 MiniMax-Hailuo-02
      # S2V (主体参考): 使用 S2V-01
      output_dir: "data/bots/_videos"
      poll_interval: 5        # 轮询间隔（秒）
      timeout: 300           # 超时时间（秒）

    # --- 自定义模型示例 ---
    # custom_video:
    #   api_url: "https://api.example.com/video"
    #   model: "my-video-model"
    #   method: "POST"
    #   task_mode: true       # true=异步任务需轮询，false=直接返回URL
    #   task_poll_url: "https://api.example.com/video/status?task_id={{task_id}}"
    #   task_poll_interval: 5
    #   task_status_field: "status"
    #   task_success_value: "Success"
    #   task_file_field: "file.download_url"
    #   # 非 task_mode 时:
    #   response_url_field: "data.video_url"

  tts:
    enabled: true
    auto: false
    provider: "edge_tts"
    model: "edge_tts"
    # MiniMax / Edge / Azure / OpenAI 仍按旧 provider 块兼容读取
    minimax:
      model: "speech-2.8-hd"  # 可选: speech-2.8-hd | 2.6 | 02
      voice: "male-qn-qingse"  # 语音ID
      speed: 1                 # 语速 0.5-2.0
      vol: 1                   # 音量 0-2
      pitch: 0                # 音调 -10~10
      sample_rate: 32000       # 采样率
      bitrate: 128000         # 比特率
      output_format: "hex"    # hex | url
      output_dir: "data/bots/_audio"

    # --- Edge TTS (微软，免费) ---
    edge_tts:
      voice: "zh-CN-XiaoxiaoNeural"  # 女声
      # 可选: zh-CN-YunxiNeural (男声), zh-CN-XiaoyiNeural (女声)

    # --- Azure TTS ---
    azure_tts:
      voice: "zh-CN-XiaoxiaoNeural"
      api_url: "https://region.tts.speech.microsoft.com/cognitiveservices/v1"
      auth_type: "api_key"

    # --- OpenAI TTS ---
    openai_tts:
      model: "tts-1"
      voice: "alloy"
      api_url: "https://api.openai.com/v1/audio/speech"
      auth_type: "bearer"

    # --- 自定义模型示例 ---
    # custom_tts:
    #   api_url: "https://api.example.com/tts"
    #   model: "my-tts-model"
    #   method: "POST"
    #   auth_type: "bearer"
    #   response_type: "url"   # url | hex | base64 | binary
    #   audio_field: "data.audio_url"
    #   body_template:
    #     text: "{{text}}"
    #     voice: "{{voice}}"
    #     model: "{{model}}"

# ============================================
# 通道配置
# ============================================
# 定义消息发送通道，不同通道支持不同媒体类型
# ============================================

channel:
  type: "cli"                # cli | feishu | webhook

  feishu:
    webhook_url: "${FEISHU_WEBHOOK_URL}"

  webhook:
    url: "${WEBHOOK_URL}"
    headers:                # 可选的自定义 headers
      # Authorization: "Bearer xxx"
