# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Project specific
# User configuration (should not be tracked)
config/*.yaml
config/*.yml
!config/*.example.yaml
!config/*.yaml.example

# User data (should not be tracked)
data/bots/*/memory/
data/bots/*/*.db
data/bots/*/*.db-wal
data/bots/*/*.db-shm
data/bots/*/proactive_state.json
data/bots/*/life_state.json
data/suqing/
data/suqing/memory/

# Built-in bot templates (keep these tracked)
# Bot persona files are templates that get copied to user dir on setup
# Exceptions for tracked test bots - must be BEFORE the generic ignore rules
!data/bots/test_proactive/
!data/bots/test_life/
# Generic persona/life.json ignore (applies to non-excepted bots)
data/bots/*/memory/
data/bots/*/proactive_state.json
data/bots/*/life_state.json
data/suqing/
data/suqing/memory/
data/bots/*/persona/
data/bots/*/life.json

# Test files
test_*.py
*.log
.artifacts/
tests/data/

# Temporary files
*.tmp
.temp/

# Frontend build
node_modules/
ai-companion-ui/.vite/
